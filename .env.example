# --- Telegram sozlamalari / Telegram settings ---
# @BotFather dan olingan bot token
TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Arizalar yuboriladigan chat/guruh/kanal ID.
# O'z ID'ingizni bilish uchun: botga yozing va @userinfobot / @getidsbot dan foydalaning.
TELEGRAM_CHAT_ID=123456789

# Server porti (ixtiyoriy)
PORT=3000
